# Modo: live (MT5 real, só Windows) | stub (dev/test sem terminal)
MT5_PROVIDER_MODE=stub

# Servidor (produção: 127.0.0.1 + Cloudflare Tunnel)
MT5_HOST=127.0.0.1
MT5_PORT=8000

# Segurança — ver docs/SECURITY.md e docs/API.md
MT5_DOCS_ENABLED=true
MT5_DEBUG_ERRORS=false
MT5_EXPOSE_INTERNAL=false
MT5_REQUIRE_AUTH=false

# MT5 terminal (opcional — live mode)
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
# MT5_PATH="C:\MT5\Instances\MT5_Conta_510075836\terminal64.exe"
# MT5_START_MINIMIZED=true   # false = janela visivel ao arrancar; true = minimizado (barra de tarefas)

# MT5_LOGIN=
# MT5_PASSWORD=
# MT5_SERVER=

# Auth multi-harness (deixe vazio para desativar em dev local)
MT5_API_KEYS=harness-crt:changeme,harness-other:changeme2

# Símbolos expostos (código harness → símbolo MT5)
# Hantec: XAUUSD:XAUUSD, US30:US30, GER40:GER40, NAS100:US100
# Fotmarkets (ex.): XAUUSD:GOLD, US30:US30Cash, GER40:GER40Cash
# Mapeamento harness → nome no broker MT5 (use discover-mt5-symbols.ps1)
# Ex. Hantec/Fotmarkets: ouro = GOLD, não XAUUSD
MT5_SYMBOLS=XAUUSD:GOLD,USDCAD:USDCAD,GBPUSD:GBPUSD,EURUSD:EURUSD,US30:US30,US100:US100,NAS100:US100,GER40:GER40,GBPJPY:GBPJPY,AUDCAD:AUDCAD,USDCHF:USDCHF,NZDUSD:NZDUSD

MT5_DEFAULT_LIMIT=500
MT5_MAX_LIMIT=3000